{
  "name": "RF-Autonomous-Lab",
  "build": { "context": "..", "dockerfile": "Dockerfile" },
  "runArgs": [ "--gpus", "all", "--ipc=host" ],
  "mounts": [
    "source=${localEnv:HOME}/.cache/pip,target=/home/vscode/.cache/pip,type=bind",
    "source=${localEnv:HOME}/.local/share/mise,target=/home/vscode/.local/share/mise,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [ "ms-python.python", "jdxcode.mise-vscode" ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "chmod +x scripts/setup && scripts/install_torch.sh"
}
